---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const products = [
  {
    name: "Gold Winged Infinity Hoodie",
    price: "$95",
    image: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/INFINETT-cotton-hoodie-white-left-front-6a0e56fa31ce1.png?v=1779614494",
    href: "https://shopinfinettcom.com/products/infinett-hoodie-1",
    tag: "Bestseller",
  },
  {
    name: "Eye of Ra Solaris Hoodie",
    price: "$92",
    image: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/Eye_of_Ra-cotton-hoodie-white-back-6a0e94327f68e.jpg?v=1779614029",
    href: "https://shopinfinettcom.com/products/unisex-cotton-hoodie-1",
    tag: "Kingdom Collection",
  },
  {
    name: "Sacred Ank Anorak",
    price: "$69",
    image: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/ank-champion-packable-anorak-black-front-6a0e94920dc60.jpg?v=1779613590",
    href: "https://shopinfinettcom.com/products/embroidered-champion-packable-jacket-4",
    tag: "New",
  },
  {
    name: "Gold Symbol Crewneck",
    price: "$87",
    image: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/INFINETT-premium-sweatshirt-black-front-6a0e68918f74b.jpg?v=1779614343",
    href: "https://shopinfinettcom.com/products/unisex-premium-sweatshirt",
    tag: "Premium",
  },
];

const symbols = [
  {
    glyph: "𓂀",
    name: "Eye of Ra",
    desc: "The all-seeing gaze of the sun god. Protection, power, royal authority.",
  },
  {
    glyph: "☥",
    name: "Ankh",
    desc: "Key of eternal life. Worn by pharaohs and gods alike. Immortality made wearable.",
  },
  {
    glyph: "∞",
    name: "Winged Infinity",
    desc: "Boundless ambition takes flight. The mark of those who refuse limits.",
  },
  {
    glyph: "🪲",
    name: "Scarab",
    desc: "Khepri's sacred beetle. Rebirth, transformation, the rising sun.",
  },
];
---

<Layout title="INFINETT — Wear the Empire">
  <Header />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-glow"></div>
      <div class="hero-grid"></div>
    </div>
    <div class="hero-content">
      <p class="hero-eyebrow">Sacred Symbols. Modern Empire.</p>
      <h1 class="hero-title">
        <span class="gold">INFINETT</span>
      </h1>
      <p class="hero-sub">
        Premium streetwear forged from the symbols of ancient kings.<br />
        Wear what pharaohs built empires upon.
      </p>
      <div class="hero-cta">
        <a href="https://shopinfinettcom.com/collections/all" target="_blank" rel="noopener noreferrer" class="btn-primary">
          Shop the Collection
        </a>
        <a href="/IRG/story" class="btn-ghost">Our Story →</a>
      </div>
      <div class="hero-badge">
        <span>∞</span>
        <span>Organic Cotton</span>
        <span class="sep">·</span>
        <span>Print-on-Demand</span>
        <span class="sep">·</span>
        <span>Free Shipping</span>
      </div>
    </div>
    <div class="scroll-hint">
      <div class="scroll-line"></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- STATEMENT BANNER -->
  <section class="marquee-wrap">
    <div class="marquee">
      <div class="marquee-track">
        {Array(6).fill(null).map(() => (
          <span>BOUNDLESS AMBITION &nbsp;∞&nbsp; SACRED SYMBOLS &nbsp;∞&nbsp; WEAR THE EMPIRE &nbsp;∞&nbsp; INFINITE RESULTS &nbsp;∞&nbsp;</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section class="products" id="collection">
    <div class="section-inner">
      <div class="section-header">
        <p class="section-eyebrow">The Collection</p>
        <h2 class="section-title">Chosen Pieces</h2>
        <p class="section-sub">
          Each garment carries a symbol that has outlasted empires.<br />Now it carries you.
        </p>
      </div>

      <div class="product-grid">
        {products.map((p) => (
          <a href={p.href} target="_blank" rel="noopener noreferrer" class="product-card">
            <div class="product-img-wrap">
              <img src={p.image} alt={p.name} loading="lazy" />
              <div class="product-overlay">
                <span>Shop Now →</span>
              </div>
              {p.tag && <span class="product-tag">{p.tag}</span>}
            </div>
            <div class="product-info">
              <h3>{p.name}</h3>
              <span class="product-price">{p.price}</span>
            </div>
          </a>
        ))}
      </div>

      <div class="products-cta">
        <a href="https://shopinfinettcom.com/collections/all" target="_blank" rel="noopener noreferrer" class="btn-primary">
          View All Products
        </a>
      </div>
    </div>
  </section>

  <!-- SYMBOLS SECTION -->
  <section class="symbols-section" id="symbols">
    <div class="section-inner">
      <div class="section-header">
        <p class="section-eyebrow">Mythology</p>
        <h2 class="section-title">The Sacred Symbols</h2>
        <p class="section-sub">Every piece tells a story older than civilization itself.</p>
      </div>
      <div class="symbols-grid">
        {symbols.map((s) => (
          <div class="symbol-card">
            <div class="symbol-glyph">{s.glyph}</div>
            <h3 class="symbol-name">{s.name}</h3>
            <p class="symbol-desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BRAND STATEMENT -->
  <section class="statement">
    <div class="statement-inner">
      <div class="statement-line"></div>
      <blockquote>
        <p class="quote-text">
          "Power does not always announce itself."
        </p>
        <p class="quote-sub">— INFINETT Brand Philosophy</p>
      </blockquote>
      <div class="statement-line"></div>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="categories">
    <div class="section-inner">
      <div class="section-header">
        <p class="section-eyebrow">Browse</p>
        <h2 class="section-title">Shop by Category</h2>
      </div>
      <div class="cat-grid">
        <a href="https://shopinfinettcom.com/collections/all" target="_blank" rel="noopener noreferrer" class="cat-card cat-large">
          <div class="cat-bg" style="background-image: url('https://cdn.shopify.com/s/files/1/0716/7790/2950/files/INFINETT-cotton-hoodie-white-left-front-6a0e56fa31ce1.png?v=1779614494')"></div>
          <div class="cat-overlay"></div>
          <div class="cat-content">
            <h3>Hoodies</h3>
            <span>From $92 →</span>
          </div>
        </a>
        <a href="https://shopinfinettcom.com/collections/all" target="_blank" rel="noopener noreferrer" class="cat-card">
          <div class="cat-bg" style="background-image: url('https://cdn.shopify.com/s/files/1/0716/7790/2950/files/eye_of_ra-champion-packable-anorak-black-front-6a0e946ec4de4.jpg?v=1779613687')"></div>
          <div class="cat-overlay"></div>
          <div class="cat-content">
            <h3>Jackets</h3>
            <span>From $69 →</span>
          </div>
        </a>
        <a href="https://shopinfinettcom.com/collections/all" target="_blank" rel="noopener noreferrer" class="cat-card">
          <div class="cat-bg" style="background-image: url('https://cdn.shopify.com/s/files/1/0716/7790/2950/files/INFINETT-organic-oversized-high-neck-blaster-2.0-t-shirt-french-navy-front-6a0e67cbdee49.png?v=1779614416')"></div>
          <div class="cat-overlay"></div>
          <div class="cat-content">
            <h3>T-Shirts</h3>
            <span>From $56 →</span>
          </div>
        </a>
        <a href="https://shopinfinettcom.com/collections/all" target="_blank" rel="noopener noreferrer" class="cat-card">
          <div class="cat-bg" style="background-image: url('https://cdn.shopify.com/s/files/1/0716/7790/2950/files/INFINETT-hat-black-front-6a0e6d41bb8d8.jpg?v=1779614240')"></div>
          <div class="cat-overlay"></div>
          <div class="cat-content">
            <h3>Accessories</h3>
            <span>From $26 →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- EMAIL CAPTURE -->
  <section class="email-section">
    <div class="email-inner">
      <div class="email-symbol">∞</div>
      <h2>Join the Empire</h2>
      <p>Be first to know about new drops, limited releases, and sacred lore.</p>
      <form
        class="email-form"
        action="https://shopinfinettcom.com/contact"
        method="POST"
        target="_blank"
      >
        <input
          type="email"
          name="contact[email]"
          placeholder="Your email address"
          required
        />
        <button type="submit">Subscribe</button>
      </form>
      <p class="email-note">No spam. Ever. Unsubscribe anytime.</p>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-glow {
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(212, 175, 55, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212, 175, 55, 0.04) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 820px;
    padding: 8rem 2rem 4rem;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .hero-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(4rem, 14vw, 10rem);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .gold {
    background: linear-gradient(135deg, var(--gold-dark), var(--gold), var(--gold-light), var(--gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    color: var(--gray);
    font-size: 1.05rem;
    line-height: 1.8;
    max-width: 500px;
    margin: 0 auto 2.5rem;
  }

  .hero-cta {
    display: flex;
    gap: 1.2rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .btn-primary {
    background: var(--gold);
    color: var(--black);
    padding: 0.9rem 2.4rem;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-primary:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(212, 175, 55, 0.3);
  }

  .btn-ghost {
    color: var(--white);
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    padding: 0.9rem 1.5rem;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 2px;
    transition: border-color 0.2s, color 0.2s;
    text-transform: uppercase;
  }

  .btn-ghost:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  .hero-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.08em;
    flex-wrap: wrap;
  }

  .hero-badge .sep {
    opacity: 0.3;
  }

  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.3);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, transparent, var(--gold));
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  /* MARQUEE */
  .marquee-wrap {
    overflow: hidden;
    background: var(--gold);
    padding: 0.9rem 0;
  }

  .marquee-track {
    display: flex;
    white-space: nowrap;
    animation: marqueeScroll 25s linear infinite;
  }

  .marquee-track span {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--black);
    padding-right: 2rem;
  }

  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* SECTIONS */
  .section-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .section-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .section-sub {
    color: var(--gray);
    font-size: 0.95rem;
    line-height: 1.8;
  }

  /* PRODUCTS */
  .products {
    padding: 7rem 0;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .product-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .product-img-wrap {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: var(--dark-3);
    margin-bottom: 1rem;
  }

  .product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .product-card:hover .product-img-wrap img {
    transform: scale(1.06);
  }

  .product-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .product-overlay span {
    background: var(--gold);
    color: var(--black);
    padding: 0.6rem 1.5rem;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 2px;
  }

  .product-card:hover .product-overlay {
    opacity: 1;
  }

  .product-tag {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--gold);
    color: var(--black);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 1px;
  }

  .product-info {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .product-info h3 {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--white);
    line-height: 1.4;
    flex: 1;
    margin-right: 1rem;
  }

  .product-price {
    font-family: 'Cinzel', serif;
    font-size: 0.95rem;
    color: var(--gold);
    font-weight: 600;
    white-space: nowrap;
  }

  .products-cta {
    text-align: center;
    margin-top: 1rem;
  }

  /* SYMBOLS */
  .symbols-section {
    padding: 7rem 0;
    background: var(--dark-2);
  }

  .symbols-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .symbol-card {
    text-align: center;
    padding: 2.5rem 1.5rem;
    border: 1px solid rgba(212, 175, 55, 0.1);
    border-radius: 4px;
    background: rgba(212, 175, 55, 0.02);
    transition: border-color 0.3s, transform 0.2s;
  }

  .symbol-card:hover {
    border-color: rgba(212, 175, 55, 0.4);
    transform: translateY(-4px);
  }

  .symbol-glyph {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .symbol-name {
    font-family: 'Cinzel', serif;
    font-size: 1rem;
    color: var(--gold);
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }

  .symbol-desc {
    font-size: 0.82rem;
    color: var(--gray);
    line-height: 1.7;
  }

  /* STATEMENT */
  .statement {
    padding: 6rem 0;
  }

  .statement-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .statement-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(212, 175, 55, 0.4), transparent);
  }

  .quote-text {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    color: var(--white);
    text-align: center;
    font-style: italic;
    white-space: nowrap;
  }

  .quote-sub {
    font-size: 0.75rem;
    color: rgba(212, 175, 55, 0.5);
    letter-spacing: 0.15em;
    text-align: center;
    margin-top: 0.5rem;
    text-transform: uppercase;
  }

  /* CATEGORIES */
  .categories {
    padding: 7rem 0;
    background: var(--dark-2);
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: 1rem;
  }

  .cat-card {
    position: relative;
    overflow: hidden;
    text-decoration: none;
    border-radius: 2px;
    aspect-ratio: 3/4;
    display: block;
  }

  .cat-large {
    grid-row: 1 / 3;
    aspect-ratio: auto;
  }

  .cat-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.5s ease;
  }

  .cat-card:hover .cat-bg {
    transform: scale(1.06);
  }

  .cat-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.2) 60%, transparent 100%);
  }

  .cat-content {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    right: 1.5rem;
  }

  .cat-content h3 {
    font-family: 'Cinzel', serif;
    font-size: 1.3rem;
    color: var(--white);
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .cat-content span {
    font-size: 0.8rem;
    color: var(--gold);
    font-weight: 500;
  }

  /* EMAIL */
  .email-section {
    padding: 7rem 0;
    text-align: center;
  }

  .email-inner {
    max-width: 560px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .email-symbol {
    font-size: 3rem;
    color: var(--gold);
    margin-bottom: 1.5rem;
    line-height: 1;
  }

  .email-section h2 {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--white);
  }

  .email-section p {
    color: var(--gray);
    margin-bottom: 2rem;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .email-form {
    display: flex;
    gap: 0;
    max-width: 440px;
    margin: 0 auto 0.75rem;
  }

  .email-form input {
    flex: 1;
    background: var(--dark-3);
    border: 1px solid rgba(212, 175, 55, 0.2);
    border-right: none;
    color: var(--white);
    padding: 0.85rem 1.2rem;
    font-size: 0.9rem;
    outline: none;
    border-radius: 2px 0 0 2px;
    transition: border-color 0.2s;
  }

  .email-form input:focus {
    border-color: var(--gold);
  }

  .email-form input::placeholder {
    color: rgba(255,255,255,0.3);
  }

  .email-form button {
    background: var(--gold);
    color: var(--black);
    border: none;
    padding: 0.85rem 1.5rem;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 0 2px 2px 0;
    transition: background 0.2s;
  }

  .email-form button:hover {
    background: var(--gold-light);
  }

  .email-note {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.25);
    margin-bottom: 0;
  }

  /* RESPONSIVE */
  @media (max-width: 1100px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .symbols-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .cat-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .cat-large {
