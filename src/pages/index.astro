---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const featured = [
  {
    name: "Gold Winged Infinity Hoodie",
    price: "$95",
    image: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/INFINETT-cotton-hoodie-white-left-front-6a0e56fa31ce1.png?v=1779614494",
    href: "https://shopinfinettcom.com/products/infinett-hoodie-1",
    tag: "Bestseller",
  },
  {
    name: "Eye of Ra Solaris Hoodie",
    price: "$92",
    image: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/Eye_of_Ra-cotton-hoodie-white-back-6a0e94327f68e.jpg?v=1779614029",
    href: "https://shopinfinettcom.com/products/unisex-cotton-hoodie-1",
    tag: "Kingdom Drop",
  },
  {
    name: "Wings Down Anorak",
    price: "$69",
    image: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/unisex-champion-packable-anorak-black-front-6a1392b2c8a49.jpg?v=1779667646",
    href: "https://shopinfinettcom.com/products/infinett-wings-down-anorak",
    tag: "New",
  },
  {
    name: "Sacred Empire Bomber",
    price: "$72.50",
    image: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/all-over-print-unisex-bomber-jacket-white-front-6a1fd23bc5817.png?v=1780470369",
    href: "https://shopinfinettcom.com/products/infinett-sacred-empire-bomber-jacket",
    tag: "New",
  },
];

const categories = [
  { name: "Hoodies",    sub: "From $92", href: "https://shopinfinettcom.com/collections/hoodies",                    img: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/INFINETT-cotton-hoodie-white-left-front-6a0e56fa31ce1.png?v=1779614494" },
  { name: "Anoraks",    sub: "From $69", href: "https://shopinfinettcom.com/collections/infinett-anorak-collection", img: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/eye_of_ra-champion-packable-anorak-black-front-6a0e946ec4de4.jpg?v=1779613687" },
  { name: "T-Shirts",   sub: "From $56", href: "https://shopinfinettcom.com/collections/t-shirts",                   img: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/INFINETT-organic-oversized-high-neck-blaster-2.0-t-shirt-french-navy-front-6a0e67cbdee49.png?v=1779614416" },
  { name: "Jerseys",    sub: "From $70", href: "https://shopinfinettcom.com/collections/jerseys",                    img: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/all-over-print-recycled-unisex-sports-jersey-white-back-6a1ebc3e98a73.jpg?v=1780399207" },
  { name: "Crewnecks",  sub: "From $87", href: "https://shopinfinettcom.com/collections/sweatshirts",                img: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/INFINETT-premium-sweatshirt-black-front-6a0e68918f74b.jpg?v=1779614343" },
  { name: "Accessories",sub: "From $26", href: "https://shopinfinettcom.com/collections/accessories",                img: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/INFINETT-hat-black-front-6a0e6d41bb8d8.jpg?v=1779614240" },
];

const symbols = [
  { glyph: "𓂀", name: "Eye of Ra",       desc: "All-seeing protection. Solar authority. The gaze that judges and guards." },
  { glyph: "☥",  name: "Ankh",            desc: "Key of eternal life. Worn by pharaohs and gods. Immortality made wearable." },
  { glyph: "∞",  name: "Winged Infinity", desc: "Boundless ambition takes flight. The mark of those who refuse limits." },
  { glyph: "𓆣", name: "Scarab of Khepri",desc: "Rebirth, transformation, the rising sun. Ancient cipher of new beginnings." },
];

const stats = [
  { num: "28+",  label: "Unique Designs" },
  { num: "6",    label: "Product Categories" },
  { num: "100%", label: "Premium Materials" },
  { num: "∞",    label: "Dropping Monthly" },
];
---

<Layout
  title="INFINETT — Wear the Empire"
  description="Premium Egyptian mythology streetwear. Sacred symbols. Boundless ambition. Wear what pharaohs built empires upon."
>
  <Header />

  <!-- ANNOUNCEMENT BAR -->
  <div class="announce-bar">
    <span>Free shipping on orders $75+ &nbsp;·&nbsp; New sacred drops monthly &nbsp;·&nbsp; Premium print-on-demand quality</span>
  </div>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="hero-grid"></div>

    <div class="hero-layout">
      <div class="hero-text">
        <p class="hero-eyebrow">Egyptian Mythology Streetwear</p>
        <h1 class="hero-title">
          Wear the<br /><span class="gold-text">Empire.</span>
        </h1>
        <p class="hero-sub">
          Premium streetwear forged from the symbols of ancient kings.
          Sacred geometry. Boundless ambition. Every piece tells a story
          older than civilization.
        </p>
        <div class="hero-actions">
          <a href="https://shopinfinettcom.com/collections/all" target="_blank" rel="noopener noreferrer" class="btn-primary">
            Shop the Collection
          </a>
          <a href={`${base}story`} class="btn-outline">Our Story →</a>
        </div>
        <div class="trust-row">
          <span>🔒 Secure Checkout</span>
          <span>✦ Premium Quality</span>
          <span>🌍 Ships Worldwide</span>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-img-wrap">
          <div class="hero-img-glow"></div>
          <img
            src="https://cdn.shopify.com/s/files/1/0716/7790/2950/files/INFINETT-cotton-hoodie-white-left-front-6a0e56fa31ce1.png?v=1779614494"
            alt="INFINETT Gold Winged Infinity Hoodie"
            class="hero-img"
          />
          <div class="hero-badge-float">
            <span class="badge-label">Bestseller</span>
            <span class="badge-price">$95</span>
          </div>
        </div>
      </div>
    </div>

    <div class="scroll-cue">
      <div class="scroll-line"></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee-bar">
    <div class="marquee-track">
      {Array(8).fill(null).map(() => (
        <span>BOUNDLESS AMBITION &nbsp;∞&nbsp; SACRED SYMBOLS &nbsp;∞&nbsp; WEAR THE EMPIRE &nbsp;∞&nbsp; INFINITE RESULTS &nbsp;∞&nbsp;</span>
      ))}
    </div>
  </div>

  <!-- TRUST BAR -->
  <div class="trust-bar">
    <div class="trust-bar-inner">
      {[
        { icon: "🚀", title: "Ships Worldwide", sub: "Print-on-demand fulfillment" },
        { icon: "🌿", title: "Premium Materials", sub: "Organic cotton & recycled fabrics" },
        { icon: "🔒", title: "Secure Checkout", sub: "SSL encrypted transactions" },
        { icon: "✦",  title: "New Drops Monthly", sub: "Sacred collection expanding" },
      ].map(t => (
        <div class="trust-item">
          <span class="trust-icon">{t.icon}</span>
          <div>
            <p class="trust-title">{t.title}</p>
            <p class="trust-sub">{t.sub}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- FEATURED PRODUCTS -->
  <section class="products-section">
    <div class="section-inner">
      <div class="section-header">
        <p class="eyebrow">The Collection</p>
        <h2 class="section-title">Chosen Pieces</h2>
        <p class="section-sub">Each garment carries a symbol that has outlasted empires. Now it carries you.</p>
      </div>

      <div class="product-grid">
        {featured.map((p) => (
          <a href={p.href} target="_blank" rel="noopener noreferrer" class="product-card">
            <div class="card-img-wrap">
              <img src={p.image} alt={p.name} loading="lazy" />
              <div class="card-hover-cta">Shop Now →</div>
              {p.tag && <span class="card-tag">{p.tag}</span>}
            </div>
            <div class="card-info">
              <h3>{p.name}</h3>
              <span class="card-price">{p.price}</span>
            </div>
          </a>
        ))}
      </div>

      <div class="products-footer">
        <a href="https://shopinfinettcom.com/collections/all" target="_blank" rel="noopener noreferrer" class="btn-primary">
          View All 28 Designs →
        </a>
      </div>
    </div>
  </section>

  <!-- BRAND STATEMENT -->
  <section class="brand-statement">
    <div class="statement-glow"></div>
    <div class="statement-inner">
      <div class="statement-symbol">∞</div>
      <h2 class="statement-quote">
        "Power does not<br />always announce itself."
      </h2>
      <p class="statement-body">
        INFINETT was built on a simple truth: the most powerful symbols in
        human history weren't shouted — they were worn. Pharaohs carried the
        Ankh. Gods bore the Eye of Ra. The empire was always in the emblem.
      </p>
      <a href={`${base}story`} class="btn-outline-gold">Read Our Story →</a>
    </div>
  </section>

  <!-- SHOP BY CATEGORY -->
  <section class="categories-section">
    <div class="section-inner">
      <div class="section-header">
        <p class="eyebrow">Browse</p>
        <h2 class="section-title">Shop by Category</h2>
      </div>

      <div class="cat-grid">
        {categories.map((c, i) => (
          <a
            href={c.href}
            target="_blank"
            rel="noopener noreferrer"
            class={`cat-card ${i === 0 ? 'cat-featured' : ''}`}
          >
            <div
              class="cat-bg"
              style={`background-image: url('${c.img}')`}
            ></div>
            <div class="cat-overlay"></div>
            <div class="cat-content">
              <h3>{c.name}</h3>
              <span>{c.sub} →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SACRED SYMBOLS -->
  <section class="symbols-section">
    <div class="section-inner">
      <div class="section-header">
        <p class="eyebrow">Mythology</p>
        <h2 class="section-title">The Sacred Symbols</h2>
        <p class="section-sub">Every piece tells a story older than civilization itself.</p>
      </div>
      <div class="symbols-grid">
        {symbols.map((s) => (
          <div class="symbol-card">
            <div class="symbol-glyph">{s.glyph}</div>
            <h3 class="symbol-name">{s.name}</h3>
            <p class="symbol-desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS STRIP -->
  <div class="stats-strip">
    {stats.map(s => (
      <div class="stat-item">
        <span class="stat-num">{s.num}</span>
        <span class="stat-label">{s.label}</span>
      </div>
    ))}
  </div>

  <!-- EMAIL CAPTURE -->
  <section class="email-section">
    <div class="email-inner">
      <p class="eyebrow">Join the Inner Circle</p>
      <h2>Be First to the Empire</h2>
      <p class="email-sub">
        New drops. Sacred lore. Members-only offers.<br />
        No spam. Unsubscribe anytime.
      </p>
      <form class="email-form" action="https://shopinfinettcom.com/contact" method="POST" target="_blank">
        <input type="hidden" name="contact[tags]" value="newsletter" />
        <div class="email-row">
          <input
            type="email"
            name="contact[email]"
            placeholder="Your email address"
            required
          />
          <button type="submit">Join →</button>
        </div>
      </form>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ANNOUNCE BAR */
  .announce-bar {
    background: var(--dark-3);
    border-bottom: 1px solid rgba(212,175,55,0.1);
    text-align: center;
    padding: 0.55rem 1rem;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 99;
  }

  /* shift header below announce bar */
  :global(#header) { top: 33px !important; }

  /* HERO */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: calc(72px + 33px);
  }

  .hero-glow {
    position: absolute;
    top: 10%; right: -10%;
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(212,175,55,0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(212,175,55,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212,175,55,0.03) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 80% 80% at 60% 50%, black 20%, transparent 80%);
    pointer-events: none;
  }

  .hero-layout {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
  }

  .hero-text { display: flex; flex-direction: column; gap: 0; }

  .hero-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 900;
    line-height: 1;
    margin-bottom: 1.5rem;
    color: var(--white);
  }

  .gold-text {
    background: linear-gradient(135deg, var(--gold-dark), var(--gold), var(--gold-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    color: var(--gray);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    max-width: 440px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .trust-row {
    display: flex;
    gap: 1.5rem;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.06em;
    flex-wrap: wrap;
  }

  /* HERO VISUAL */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-img-wrap {
    position: relative;
    width: 100%;
    max-width: 480px;
  }

  .hero-img-glow {
    position: absolute;
    inset: -20%;
    background: radial-gradient(circle, rgba(212,175,55,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 40px 80px rgba(0,0,0,0.8));
    animation: heroFloat 6s ease-in-out infinite;
  }

  @keyframes heroFloat {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-12px); }
  }

  .hero-badge-float {
    position: absolute;
    bottom: 10%;
    left: -2rem;
    z-index: 2;
    background: var(--dark-3);
    border: 1px solid rgba(212,175,55,0.3);
    border-radius: 4px;
    padding: 0.75rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }

  .badge-label {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
  }

  .badge-price {
    font-family: 'Cinzel', serif;
    font-size: 1.2rem;
    color: var(--white);
    font-weight: 700;
  }

  /* SCROLL CUE */
  .scroll-cue {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.25);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, transparent, var(--gold));
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse { 0%,100%{ opacity:.3 } 50%{ opacity:1 } }

  /* MARQUEE */
  .marquee-bar {
    overflow: hidden;
    background: var(--gold);
    padding: 0.85rem 0;
  }

  .marquee-track {
    display: flex;
    white-space: nowrap;
    animation: marquee 30s linear infinite;
  }

  .marquee-track span {
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: var(--black);
    padding-right: 2rem;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* TRUST BAR */
  .trust-bar {
    background: var(--dark-2);
    border-bottom: 1px solid rgba(212,175,55,0.08);
  }

  .trust-bar-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.5rem 2rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .trust-icon { font-size: 1.4rem; flex-shrink: 0; }

  .trust-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 0.1rem;
    letter-spacing: 0.05em;
  }

  .trust-sub {
    font-size: 0.7rem;
    color: var(--gray);
  }

  /* SHARED SECTION STYLES */
  .section-inner { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

  .section-header { text-align: center; margin-bottom: 4rem; }

  .eyebrow {
    font-size: 0.68rem;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .section-sub {
    color: var(--gray);
    font-size: 0.95rem;
    line-height: 1.8;
    max-width: 540px;
    margin: 0 auto;
  }

  /* PRODUCTS */
  .products-section { padding: 8rem 0; }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .product-card { text-decoration: none; color: inherit; display: block; }

  .card-img-wrap {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: var(--dark-3);
    margin-bottom: 0.9rem;
    border: 1px solid rgba(212,175,55,0.06);
    transition: border-color 0.3s;
  }

  .product-card:hover .card-img-wrap { border-color: rgba(212,175,55,0.25); }

  .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .product-card:hover .card-img-wrap img { transform: scale(1.07); }

  .card-hover-cta {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: var(--gold);
    color: var(--black);
    text-align: center;
    padding: 0.7rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transform: translateY(100%);
    transition: transform 0.3s ease;
  }

  .product-card:hover .card-hover-cta { transform: translateY(0); }

  .card-tag {
    position: absolute;
    top: 0.6rem; left: 0.6rem;
    background: var(--gold);
    color: var(--black);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
  }

  .card-info { display: flex; justify-content: space-between; align-items: flex-end; gap: 0.5rem; }

  .card-info h3 { font-size: 0.82rem; font-weight: 500; color: var(--white); line-height: 1.4; flex: 1; }

  .card-price {
    font-family: 'Cinzel', serif;
    font-size: 0.9rem;
    color: var(--gold);
    font-weight: 600;
    white-space: nowrap;
  }

  .products-footer { text-align: center; }

  /* BRAND STATEMENT */
  .brand-statement {
    position: relative;
    padding: 9rem 0;
    background: var(--dark-2);
    overflow: hidden;
    text-align: center;
  }

  .statement-glow {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(212,175,55,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .statement-inner { position: relative; z-index: 1; max-width: 800px; margin: 0 auto; padding: 0 2rem; }

  .statement-symbol {
    font-size: 4rem;
    color: var(--gold);
    opacity: 0.4;
    margin-bottom: 2rem;
    line-height: 1;
  }

  .statement-quote {
    font-family: 'Cinzel', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 2rem;
    font-style: italic;
  }

  .statement-body {
    color: var(--gray);
    font-size: 1rem;
    line-height: 1.9;
    margin-bottom: 2.5rem;
  }

  /* CATEGORIES */
  .categories-section { padding: 8rem 0; }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 320px 320px;
    gap: 1rem;
  }

  .cat-featured {
    grid-row: 1 / 3;
  }

  .cat-card {
    position: relative;
    overflow: hidden;
    text-decoration: none;
    display: block;
    border: 1px solid rgba(212,175,55,0.06);
    transition: border-color 0.3s;
  }

  .cat-card:hover { border-color: rgba(212,175,55,0.3); }

