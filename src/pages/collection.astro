  // JERSEYS
  { name: "Sacred Symbol Recycled Jersey",    price: "$70",    image: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/all-over-print-recycled-unisex-sports-jersey-white-back-6a1ebc3e98a73.jpg?v=1780399207",                                                                href: "https://shopinfinettcom.com/products/recycled-unisex-sports-jersey",                    tag: "Eco",        category: "Jerseys" },
  { name: "Sacred Crest Recycled Jersey",     price: "$70",    image: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/all-over-print-recycled-unisex-sports-jersey-white-front-6a1fd00f7a2fb.png?v=1780469817",                                                               href: "https://shopinfinettcom.com/products/recycled-unisex-sports-jersey-1",                  tag: "Eco",        category: "Jerseys" },
  // TANK TOPS
  { name: "Wings Down Premium Tank Top",      price: "$40",    image: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/INFINETT_mens-premium-tank-top-black-front-6a0f3fe3b56eb.jpg?v=1779612108",                                                                             href: "https://shopinfinettcom.com/products/men-s-premium-tank-top-1",                        tag: "",           category: "Tank Tops" },
  // ACCESSORIES
  { name: "Winged Infinity Hat",              price: "$26",    image: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/INFINETT-hat-black-front-6a0e6d41bb8d8.jpg?v=1779614240",                                                                                               href: "https://shopinfinettcom.com/products/dad-hat-1",                                        tag: "",           category: "Accessories" },
];

const categories = ["All", "Hoodies", "Jackets", "T-Shirts", "Sweatshirts", "Jerseys", "Tank Tops", "Accessories"];
---

<Layout
  title="Full Collection — INFINETT"
  description="Browse the complete INFINETT collection. Egyptian mythology streetwear including hoodies, anoraks, jerseys, tees and accessories."
>
  <Header />

  <main class="collection-main">
    <div class="col-hero">
      <div class="col-hero-glow"></div>
      <div class="col-hero-inner">
        <p class="eyebrow">INFINETT</p>
        <h1>The Full Collection</h1>
        <p class="col-hero-sub">{products.length} pieces. Sacred symbols. Built for empire builders.</p>
      </div>
    </div>

    <div class="col-body">
      <div class="col-body-inner">
        <div class="filter-bar">
          <span class="filter-label">Filter:</span>
          <div class="filter-pills" id="filters">
            {categories.map((cat, i) => (
              <button class={`filter-pill ${i === 0 ? 'active' : ''}`} data-cat={cat}>
                {cat}
                {cat !== "All" && <span class="pill-count">{products.filter(p => p.category === cat).length}</span>}
              </button>
            ))}
          </div>
          <span class="product-count" id="product-count">{products.length} products</span>
        </div>

        <div class="product-grid" id="product-grid">
          {products.map((p) => (
            <a href={p.href} target="_blank" rel="noopener noreferrer" class="product-card" data-category={p.category}>
              <div class="card-img-wrap">
                <img src={p.image} alt={p.name} loading="lazy" />
                <div class="card-overlay">Shop Now →</div>
                {p.tag && <span class="card-tag">{p.tag}</span>}
              </div>
              <div class="card-info">
                <h3>{p.name}</h3>
                <div class="card-meta">
                  <span class="card-cat">{p.category}</span>
                  <span class="card-price">{p.price}</span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <div class="empty-state" id="empty-state" style="display:none;">
          <div class="empty-symbol">∞</div>
          <h3>No pieces in this category yet.</h3>
          <p>New drops monthly — check back soon.</p>
        </div>

        <div class="col-cta">
          <a href="https://shopinfinettcom.com/collections/all" target="_blank" rel="noopener noreferrer" class="btn-primary">
            Shop All on Store →
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const pills = document.querySelectorAll('.filter-pill');
  const cards = document.querySelectorAll('.product-card');
  const counter = document.getElementById('product-count');
  const emptyState = document.getElementById('empty-state');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const cat = (pill as HTMLElement).dataset.cat;
      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');

      let visible = 0;
      cards.forEach(card => {
        const show = cat === 'All' || (card as HTMLElement).dataset.category === cat;
        (card as HTMLElement).style.display = show ? 'block' : 'none';
        if (show) visible++;
      });

      if (counter) counter.textContent = `${visible} product${visible !== 1 ? 's' : ''}`;
      if (emptyState) emptyState.style.display = visible === 0 ? 'block' : 'none';
    });
  });
</script>

<style>
  .collection-main { padding-top: 72px; }

  .col-hero {
    position: relative;
    padding: 6rem 2rem 5rem;
    text-align: center;
    overflow: hidden;
    background: var(--dark-2);
    border-bottom: 1px solid rgba(212,175,55,0.08);
  }

  .col-hero-glow {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 600px; height: 400px;
    background: radial-gradient(ellipse, rgba(212,175,55,0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .col-hero-inner { position: relative; z-index: 1; }

  .eyebrow {
    font-size: 0.68rem;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .col-hero h1 {
    font-family: 'Cinzel', serif;
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .col-hero-sub { color: var(--gray); font-size: 0.95rem; }

  .col-body { padding: 4rem 0 8rem; }
  .col-body-inner { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

  .filter-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    flex-shrink: 0;
  }

  .filter-pills { display: flex; gap: 0.5rem; flex-wrap: wrap; flex: 1; }

  .filter-pill {
    background: none;
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.5);
    padding: 0.4rem 0.9rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 2px;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .filter-pill:hover { border-color: rgba(212,175,55,0.4); color: var(--gold); }
  .filter-pill.active { background: var(--gold); border-color: var(--gold); color: var(--black); }
  .pill-count { font-size: 0.6rem; opacity: 0.6; }
  .filter-pill.active .pill-count { opacity: 0.7; }

  .product-count {
    margin-left: auto;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .product-card { text-decoration: none; color: inherit; display: block; }

  .card-img-wrap {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: var(--dark-3);
    margin-bottom: 0.9rem;
    border: 1px solid rgba(212,175,55,0.06);
    transition: border-color 0.3s;
  }

  .product-card:hover .card-img-wrap { border-color: rgba(212,175,55,0.3); }

  .card-img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .product-card:hover .card-img-wrap img { transform: scale(1.07); }

  .card-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: var(--gold);
    color: var(--black);
    text-align: center;
    padding: 0.65rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transform: translateY(100%);
    transition: transform 0.3s ease;
  }

  .product-card:hover .card-overlay { transform: translateY(0); }

  .card-tag {
    position: absolute;
    top: 0.6rem; left: 0.6rem;
    background: var(--gold);
    color: var(--black);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
  }

  .card-info h3 {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--white);
    line-height: 1.4;
    margin-bottom: 0.4rem;
  }

  .card-meta { display: flex; justify-content: space-between; align-items: center; }

  .card-cat {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .card-price {
    font-family: 'Cinzel', serif;
    font-size: 0.88rem;
    color: var(--gold);
    font-weight: 600;
  }

  .empty-state { text-align: center; padding: 6rem 2rem; }
  .empty-symbol { font-size: 4rem; color: rgba(212,175,55,0.2); margin-bottom: 1.5rem; }
  .empty-state h3 { font-family: 'Cinzel', serif; font-size: 1.3rem; color: var(--white); margin-bottom: 0.75rem; }
  .empty-state p { color: var(--gray); font-size: 0.9rem; }

  .col-cta { text-align: center; margin-top: 2rem; }

  .btn-primary {
    background: var(--gold);
    color: var(--black);
    padding: 0.9rem 2.4rem;
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    display: inline-block;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .btn-primary:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(212,175,55,0.3);
  }

  @media (max-width: 1024px) { .product-grid { grid-template-columns: repeat(3,1fr); } }
  @media (max-width: 768px) {
    .product-grid { grid-template-columns: repeat(2,1fr); gap: 1rem; }
    .filter-bar { flex-direction: column; align-items: flex-start; }
    .product-count { margin-left: 0; }
  }
  @media (max-width: 480px) { .product-grid { gap: 0.75rem; } }
</style>
