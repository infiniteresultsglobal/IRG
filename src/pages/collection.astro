  { name: "Gold Symbol Crewneck",             price: "$87",    image: "https://cdn.shopify.com/s/files/1/0716/7790/2950/files/INFINETT-premium-sweatshirt-black-front-6a0e68918f74b.jpg?v=1779614343",                                                                                href: "https://shopinfinettcom.com/products/unisex-premium-sweatshirt",                        tag: "",           category: "Sweatshirts" },
